DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro
CHAT_MODEL=deepseek-chat
REASONING_MODEL=deepseek-v4-pro

ZHIPU_API_KEY=your-zhipu-key-here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_FLASH_MODEL=glm-4.7-flash

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=RainN0Coding

LLM_TIMEOUT=120
LLM_FALLBACK_TIMEOUT=60

MILVUS_MODE=lite
MILVUS_HOST=localhost
MILVUS_PORT=19530

LOCAL_EMBEDDING_ENABLED=false
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

SERVER_PORT=8000
APP_ENV=development
INTERNAL_API_TOKEN=
INTERNAL_API_ALLOW_MISSING_TOKEN=true
AGENT_MAX_CONCURRENT_REQUESTS=4
AGENT_OVERLOAD_STATUS_CODE=429
AGENT_RESILIENCE_ENABLED=true
AGENT_PHASE_TIMEOUT_SHORT_SECONDS=30
AGENT_PHASE_TIMEOUT_MEDIUM_SECONDS=90
AGENT_PHASE_TIMEOUT_LONG_SECONDS=240

GUARDRAILS_ENABLED=true
GUARDRAILS_AUDIT_LOW_RISK=false
GUARDRAILS_MAX_PROMPT_CHARS=12000
GUARDRAILS_MAX_FILE_WRITE_BYTES=200000
GUARDRAILS_MAX_MODIFY_REPLACEMENT_BYTES=120000
GUARDRAILS_MAX_LIST_FILES_DEPTH=6

RAG_TOP_K=8
RAG_DEDUP_THRESHOLD=0.95
RAG_PARALLEL_WORKERS=5
SQLITE_DB_PATH=rag_data/exact_search.db
CODE_STORE_DIR=verified_code
USE_HYBRID_ENGINE=true
RAG_CACHE_TTL_COLD=1800
RAG_CACHE_TTL_HOT=7200
RAG_HOT_QUERY_WINDOW=600
RAG_HOT_QUERY_THRESHOLD=10

REDIS_HOST=localhost
REDIS_PORT=6379

MEMORY_WINDOW_SIZE=10
MEMORY_SUMMARY_TRIGGER=15
MEMORY_REDIS_TTL_SECONDS=2592000

QUALITY_SCORE_THRESHOLD=80
QUALITY_MIN_AGE_DAYS=30
QUALITY_CLEANUP_INTERVAL_HOURS=24
QUALITY_INITIAL_SCORE=70.0
QUALITY_BOOST_ON_SUCCESS=5.0
QUALITY_PENALTY_ON_FAILURE=10.0
